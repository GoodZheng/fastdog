<Window x:Class="FastDog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FastDog - 文本搜索" Height="650" Width="1000"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop"
        DataContext="{StaticResource MainViewModel}">
    <DockPanel>
        <!-- 搜索条件区 -->
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0: 搜索路径 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="搜索路径:"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding SearchPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,2"/>
                <Button Grid.Row="0" Grid.Column="2" Content="浏览..."
                        Command="{Binding BrowseCommand}" Margin="6,2,0,2" Padding="12,2"/>

                <!-- Row 1: 搜索内容 + 选项 -->
                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,0"/>
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal"
                            Margin="6,4,0,0">
                    <RadioButton Content="正则" IsChecked="{Binding IsRegex}"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <RadioButton Content="文本" IsChecked="{Binding IsPlainText}"
                                 Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <CheckBox Content="区分大小写" IsChecked="{Binding CaseSensitive}"
                              Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <CheckBox Content="全词" IsChecked="{Binding WholeWord}"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Row 2: 文件过滤 + 排除目录 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="文件过滤:"
                           VerticalAlignment="Center" Margin="0,4,6,0"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding FileFilter, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,0"/>
                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal"
                            Margin="6,4,0,0">
                    <TextBlock Text="排除目录:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding ExcludeDirs, UpdateSourceTrigger=PropertyChanged}"
                             Width="180"/>
                </StackPanel>

                <!-- Row 3: 日期 + 按钮 -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" Margin="0,6,0,0">
                    <CheckBox Content="修改日期:" IsChecked="{Binding DateFilterEnabled}"
                              VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding DateFrom}" Width="120"
                                IsEnabled="{Binding DateFilterEnabled}"/>
                    <TextBlock Text="~" VerticalAlignment="Center" Margin="4,0"/>
                    <DatePicker SelectedDate="{Binding DateTo}" Width="120"
                                IsEnabled="{Binding DateFilterEnabled}"/>
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="6,6,0,0">
                    <Button Content="搜索" Command="{Binding SearchCommand}"
                            Padding="20,4" IsDefault="True"/>
                    <Button Content="取消" Command="{Binding CancelCommand}"
                            Padding="12,4" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="文件: "/>
                    <TextBlock Text="{Binding TotalFiles, Mode=OneWay}" FontWeight="Bold"/>
                    <TextBlock Text=" | 匹配: " Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding TotalMatches, Mode=OneWay}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ElapsedTime, StringFormat=' | {0}'}" Margin="8,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- 中间：结果区 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 文件列表 -->
            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding SearchResults}"
                      SelectedItem="{Binding SelectedResult}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="打开文件" Command="{Binding OpenFileCommand}"/>
                        <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}"/>
                        <MenuItem Header="复制文件名" Command="{Binding CopyFileNameCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="200"/>
                    <DataGridTextColumn Header="大小" Binding="{Binding FileSize, StringFormat='{}{0:N0}'}" Width="80"/>
                    <DataGridTextColumn Header="匹配数" Binding="{Binding MatchCount}" Width="60"/>
                    <DataGridTextColumn Header="路径" Binding="{Binding RelativePath}" Width="*"/>
                    <DataGridTextColumn Header="修改时间" Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"/>

            <!-- 行内容预览 -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding MatchLines}"
                     SelectedItem="{Binding SelectedMatchLine}"
                     MouseDoubleClick="MatchList_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding LineNumber}" Width="50"
                                       Foreground="Gray" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LineText}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>
