<Window x:Class="FastDog.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="提示"
        Width="400" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="Assets/newLogo1.2.ico"
        UseLayoutRounding="True"
        Background="#f3f3f3">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" GlassFrameThickness="-1"
                            ResizeBorderThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Border Background="{TemplateBinding Background}">
                <ContentPresenter/>
            </Border>
        </ControlTemplate>
    </Window.Template>

    <DockPanel>
        <!-- 标题栏 -->
        <Border DockPanel.Dock="Top" Height="36" Background="#faf8f3"
                BorderBrush="#ebe6da" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="Assets/newLogo1.2.ico" Width="22" Height="22" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Fast" FontWeight="ExtraBold" FontSize="13" Foreground="#e74c3c"/>
                        <Run Text="Dog" FontWeight="ExtraBold" FontSize="13" Foreground="#1e1e1e"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource CaptionCloseButton}"
                            Click="CloseButton_Click"
                            ToolTip="关闭"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Width="11" Height="11" Stroke="#1e1e1e" StrokeThickness="1.1"
                              Data="M1,1 L10,10 M10,1 L1,10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 内容区 -->
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 图标 + 消息文本 -->
            <DockPanel Grid.Row="0">
                <TextBlock x:Name="IconText" DockPanel.Dock="Left"
                           FontSize="28" VerticalAlignment="Top" Margin="0,0,16,0"/>
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap" FontSize="13" Foreground="#1e1e1e"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- 按钮区 -->
            <StackPanel x:Name="ButtonPanel" Grid.Row="1"
                        Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,16,0,0"/>
        </Grid>
    </DockPanel>
</Window>
