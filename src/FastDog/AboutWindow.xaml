<Window x:Class="FastDog.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="关于 FastDog"
        Width="420" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="Assets/newLogo1.2.ico"
        UseLayoutRounding="True"
        Background="#f3f3f3">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" GlassFrameThickness="-1"
                            ResizeBorderThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Border Background="{TemplateBinding Background}">
                <ContentPresenter/>
            </Border>
        </ControlTemplate>
    </Window.Template>

    <DockPanel>
        <!-- ===== 标题栏（与主窗口一致） ===== -->
        <Border DockPanel.Dock="Top" Height="36" Background="#faf8f3"
                BorderBrush="#ebe6da" BorderThickness="0,0,0,1">
            <Grid>
                <!-- 左：图标 + 标题 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Image Source="Assets/newLogo1.2.ico" Width="22" Height="22"
                           Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Fast" FontWeight="ExtraBold" FontSize="13" Foreground="#e74c3c"/>
                        <Run Text="Dog" FontWeight="ExtraBold" FontSize="13" Foreground="#1e1e1e"/>
                        <Run Text=" — 关于" FontSize="12" Foreground="#9a9a9a"/>
                    </TextBlock>
                </StackPanel>
                <!-- 右：关闭按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="TitleCloseButton"
                            Style="{StaticResource CaptionCloseButton}"
                            Click="TitleCloseButton_Click"
                            ToolTip="关闭"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Width="11" Height="11" Stroke="#1e1e1e" StrokeThickness="1.1"
                              Data="M1,1 L10,10 M10,1 L1,10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 内容区 ===== -->
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo + 标题 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,0,0,4">
                <Image Source="Assets/newLogo1.2.ico"
                       Width="40" Height="40"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                    <Run Text="Fast" FontWeight="ExtraBold" FontSize="22" Foreground="#e74c3c"/>
                    <Run Text="Dog" FontWeight="ExtraBold" FontSize="22" Foreground="#1e1e1e"/>
                </TextBlock>
            </StackPanel>

            <!-- 版本号 -->
            <TextBlock x:Name="VersionText" Grid.Row="1"
                       HorizontalAlignment="Center"
                       FontSize="13" Foreground="#9a9a9a"
                       Margin="0,0,0,16"/>

            <!-- 简介 -->
            <TextBlock Grid.Row="2"
                       HorizontalAlignment="Center"
                       FontSize="13" Foreground="#1e1e1e"
                       TextAlignment="Center"
                       Text="基于 ripgrep 的文本搜索工具"/>

            <!-- 技术栈 -->
            <TextBlock Grid.Row="3"
                       HorizontalAlignment="Center"
                       FontSize="12" Foreground="#9a9a9a"
                       Margin="0,10,0,0">
                <Run Text=".NET 8"/>
                <Run Text=" · "/><Run Text="WPF"/>
                <Run Text=" · "/><Run Text="AvalonEdit"/>
                <Run Text=" · "/><Run Text="ripgrep 14.1.1"/>
            </TextBlock>

            <!-- GitHub 链接 -->
            <TextBlock Grid.Row="4"
                       HorizontalAlignment="Center"
                       FontSize="12" Margin="0,12,0,0">
                <Hyperlink Click="GitHubLink_Click"
                           Foreground="#0e639c"
                           TextDecorations="Underline">
                    github.com/GoodZheng/fastdog
                </Hyperlink>
            </TextBlock>

            <!-- 按钮区 -->
            <StackPanel Grid.Row="6" Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="CheckUpdateButton"
                        Content="检查更新"
                        Width="90" Height="28"
                        Click="CheckUpdateButton_Click"
                        Style="{StaticResource ActionButton}"/>
                <Button Content="关闭"
                        Width="72" Height="28" Margin="10,0,0,0"
                        Click="TitleCloseButton_Click"
                        IsCancel="True"
                        Style="{StaticResource CancelButton}"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
